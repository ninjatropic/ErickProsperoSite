---
const year = new Date().getFullYear();
---

<footer class="bg-navy text-white">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Brand -->
      <div>
        <a href="/" class="font-serif text-xl text-gold font-semibold tracking-wide block mb-3">
          Erick Prospero
        </a>
        <p class="text-white/60 text-sm leading-relaxed max-w-xs">
          Helping organizations build smarter learning and turn education into revenue.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">Navigate</h3>
        <ul class="space-y-2">
          {[
            { href: '/about', label: 'About' },
            { href: '/speaking', label: 'Speaking' },
            { href: '/media', label: 'Media' },
            { href: '/contact', label: 'Contact' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-white/70 hover:text-gold transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">Connect</h3>
        <a
          href="https://www.linkedin.com/in/erickprosperotorres/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-white/70 hover:text-gold transition-colors mb-3"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a
          href="mailto:hello@erickprospero.com"
          class="flex items-center gap-2 text-sm text-white/70 hover:text-gold transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
          hello@erickprospero.com
        </a>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/10 text-center text-xs text-white/40">
      &copy; {year} Erick Prospero. All rights reserved.
    </div>
  </div>
</footer>
