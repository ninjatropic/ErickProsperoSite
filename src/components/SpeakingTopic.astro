---
interface Props {
  title: string;
  description: string;
  featured?: boolean;
}

const { title, description, featured = false } = Astro.props;
---

{featured ? (
  <div class="border-l-4 border-gold pl-8 py-6 bg-cream">
    <p class="text-gold text-xs font-semibold uppercase tracking-widest mb-3">Featured Topic</p>
    <h3 class="font-serif text-2xl font-bold text-navy mb-4">{title}</h3>
    <p class="text-charcoal/80 leading-relaxed">{description}</p>
  </div>
) : (
  <div class="border border-charcoal/10 rounded-sm p-6 hover:border-gold/40 transition-colors">
    <h3 class="font-serif text-lg font-bold text-navy mb-3">{title}</h3>
    <p class="text-charcoal/70 text-sm leading-relaxed">{description}</p>
  </div>
)}
