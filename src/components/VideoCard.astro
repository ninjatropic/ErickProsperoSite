---
interface Props {
  platform: 'youtube' | 'vimeo';
  videoId: string;
  vimeoHash?: string;
  title: string;
  description: string;
  meta?: string;
}

const { platform, videoId, vimeoHash, title, description, meta } = Astro.props;

const src =
  platform === 'vimeo'
    ? `https://player.vimeo.com/video/${videoId}?h=${vimeoHash}&title=0&byline=0&portrait=0&badge=0&autopause=0&player_id=0&app_id=58479`
    : `https://www.youtube.com/embed/${videoId}`;
---

<div class="flex flex-col">
  <div class="relative w-full" style="padding-bottom: 56.25%; height: 0; overflow: hidden;">
    <iframe
      src={src}
      title={title}
      frameborder="0"
      allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen
      style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
    ></iframe>
  </div>
  <div class="pt-4">
    {meta && <p class="text-gold text-xs font-semibold uppercase tracking-widest mb-1">{meta}</p>}
    <h3 class="font-serif text-lg font-bold text-navy mb-2">{title}</h3>
    <p class="text-charcoal/70 text-sm leading-relaxed">{description}</p>
  </div>
</div>
